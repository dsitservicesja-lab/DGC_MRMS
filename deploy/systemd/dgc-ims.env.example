# Copy to /opt/DGC_IMS/.env and update values before starting service

ADMIN_USERNAME=admin
# Option A (simple): set a plain password (recommended for initial setup)
ADMIN_PASSWORD=ChangeMe!2026

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe!2026

# Option B (advanced): use salted hash instead of ADMIN_PASSWORD
ADMIN_SALT=aa13741a62bcfd7c
ADMIN_PASSWORD_HASH=d6fe4d498577806c6e44b0fd9276d18b171cb272b44fc4a35a58b634e2a8524a
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:////opt/DGC_IMS/dgc.db

# ── Email notifications ──────────────────────────────────────────────────────
# Gmail with an App Password (Google account > Security > App passwords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=DGC Requests <your-email@gmail.com>
EMAIL_ENABLED=1
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
